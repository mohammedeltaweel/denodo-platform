CREATE OR REPLACE VIEW iv_sales FOLDER = '/2 - integration' AS SELECT bv_salesdb_sales.id AS id, bv_salesdb_sales.promotion AS promotion, bv_salesdb_areas.country AS country, bv_salesdb_areas.area AS area, bv_salesdb_areas.description AS area_description, bv_salesdb_dates.fulldate AS fulldate, bv_salesdb_ordermethods.description AS order_method, bv_salesdb_products.name AS product_name, bv_salesdb_products.length AS length, bv_salesdb_products.width AS width, bv_salesdb_products.height AS height, bv_salesdb_products.weight AS weight FROM (((bv_salesdb_sales AS bv_salesdb_sales INNER JOIN bv_salesdb_areas AS bv_salesdb_areas ON bv_salesdb_sales.area = bv_salesdb_areas.id ) INNER JOIN bv_salesdb_ordermethods AS bv_salesdb_ordermethods ON bv_salesdb_sales.ordermethod = bv_salesdb_ordermethods.id ) INNER JOIN bv_salesdb_dates AS bv_salesdb_dates ON bv_salesdb_sales.dateid = bv_salesdb_dates.id ) INNER JOIN bv_salesdb_products AS bv_salesdb_products ON bv_salesdb_sales.product = bv_salesdb_products.id ;

ALTER VIEW iv_sales
 LAYOUT (bv_salesdb_areas = [305, 125, 200, 200], bv_salesdb_dates = [308, 269, 200, 200], bv_salesdb_ordermethods = [670, 95, 200, 200], bv_salesdb_products = [806, 266, 200, 200], bv_salesdb_sales = [561, 198, 200, 200]);

